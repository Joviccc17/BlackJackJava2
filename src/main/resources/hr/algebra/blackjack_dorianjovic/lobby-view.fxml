<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="hr.algebra.blackjack_dorianjovic.controller.LobbyController"
            style="-fx-background-color: #1a5c2a;">

    <!-- TOP: Title and status -->
    <top>
        <VBox alignment="CENTER" spacing="10" style="-fx-padding: 20;">
            <Label fx:id="lblTitle" text="Multiplayer Lobby"
                   style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;"/>
            <Label fx:id="lblStatus" text="Waiting for players..."
                   style="-fx-text-fill: #aaffaa; -fx-font-size: 14px;"/>
        </VBox>
    </top>

    <!-- CENTER: Player list + connection settings -->
    <center>
        <VBox alignment="CENTER" spacing="15" style="-fx-padding: 20;">
            <!-- Connection settings (visible when joining) -->
            <HBox fx:id="connectionArea" alignment="CENTER" spacing="10" visible="false">
                <Label text="Host:" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                <TextField fx:id="txtHost" text="localhost" prefWidth="150" style="-fx-font-size: 14px;"/>
                <Label text="Port:" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                <TextField fx:id="txtPort" text="12345" prefWidth="80" style="-fx-font-size: 14px;"/>
                <Button fx:id="btnConnect" text="Connect" onAction="#onConnect" prefWidth="100"
                        style="-fx-background-color: #2d8a4e; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand;"/>
            </HBox>

            <!-- Player list -->
            <Label text="Players:" style="-fx-text-fill: white; -fx-font-size: 16px;"/>
            <ListView fx:id="lstPlayers" prefHeight="120" prefWidth="400" style="-fx-font-size: 14px;"/>

            <!-- Chat area -->
            <Label text="Chat:" style="-fx-text-fill: white; -fx-font-size: 16px;"/>
            <TextArea fx:id="txtChatLog" prefHeight="200" prefWidth="500" editable="false"
                      style="-fx-font-size: 13px;"/>
            <HBox alignment="CENTER" spacing="10">
                <TextField fx:id="txtChatInput" promptText="Type a message..." prefWidth="400"
                           style="-fx-font-size: 13px;" onAction="#onSendChat"/>
                <Button text="Send" onAction="#onSendChat" prefWidth="80"
                        style="-fx-background-color: #2d8a4e; -fx-text-fill: white; -fx-font-size: 13px; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </center>

    <!-- BOTTOM: Action buttons -->
    <bottom>
        <HBox alignment="CENTER" spacing="15" style="-fx-padding: 15; -fx-background-color: #145224;">
            <Button fx:id="btnStartGame" text="Start Game" onAction="#onStartGame" prefWidth="150" prefHeight="40"
                    visible="false"
                    style="-fx-background-color: #d4a017; -fx-text-fill: white; -fx-font-size: 15px; -fx-cursor: hand;"/>
            <Button text="Back to Menu" onAction="#onBack" prefWidth="150" prefHeight="40"
                    style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-font-size: 15px; -fx-cursor: hand;"/>
        </HBox>
    </bottom>
</BorderPane>

