<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="15"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="hr.algebra.blackjack_dorianjovic.controller.LoadGameController"
      style="-fx-background-color: #1a5c2a;">
    <padding>
        <Insets bottom="30" left="50" right="50" top="30"/>
    </padding>

    <Label text="📂 Load Game" style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: bold;"/>

    <Label fx:id="lblLoadStatus" text="Select a saved game to load:"
           style="-fx-text-fill: #cccccc; -fx-font-size: 14px;"/>

    <ListView fx:id="lstSaves" prefHeight="250" prefWidth="600"
              style="-fx-font-size: 14px;"/>

    <HBox alignment="CENTER" spacing="15">
        <Button text="Load Selected" onAction="#onLoad" prefWidth="160" prefHeight="40"
                style="-fx-background-color: #2d8a4e; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand;"/>
        <Button text="Delete Selected" onAction="#onDelete" prefWidth="160" prefHeight="40"
                style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand;"/>
        <Button text="Generate Docs" onAction="#onGenerateDocs" prefWidth="160" prefHeight="40"
                style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand;"/>
        <Button text="Back" onAction="#onBack" prefWidth="120" prefHeight="40"
                style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand;"/>
    </HBox>
</VBox>

